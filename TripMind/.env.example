# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Google Gemini API Key (used in Supabase Edge Function)
# VITE_GEMINI_API_KEY is no longer needed in client after Edge Function migration
# GEMINI_API_KEY is set as a secret in Supabase Edge Functions
GEMINI_API_KEY="your-gemini-api-key"

# Database URL (only for running push_schema.ts locally)
DATABASE_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"
